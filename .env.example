# ─────────────────────────────────────────────
# Community Platform — environment variables
# Копирай този файл:  cp .env.example .env
# ─────────────────────────────────────────────

# SQLite база данни (файлът се създава в prisma/dev.db при migrate)
DATABASE_URL="file:./dev.db"

# Секрет за JWT токени (логин сесии). Смени на произволен низ в production!
JWT_SECRET="dev-secret-change-in-production"
